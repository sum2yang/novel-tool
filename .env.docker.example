POSTGRES_DB=novel_tools
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

APP_PORT=3000
# Leave empty for local compose builds. CI/CD will write a GHCR image ref here.
APP_IMAGE=
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/novel_tools?schema=public
BETTER_AUTH_SECRET=replace-with-a-random-base64-secret
# 本地直开时可用 http://localhost:3000；如果通过域名或反向代理访问，必须改成实际对外访问地址，
# 否则 Better Auth 会报 Invalid origin，注册、登录、退出登录都会失败。
BETTER_AUTH_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000
ENCRYPTION_KEY=replace-with-a-random-64-char-hex-key
LINUX_DO_CLIENT_ID=
LINUX_DO_CLIENT_SECRET=

PRISMA_DB_SYNC_MODE=deploy

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=novel-tools
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-password

# 用户未填写个人配置时，应用容器会按这 7 个字段逐项回退到平台默认。
# 推荐这里填写各自的上游 API 地址，而不是外部 GrokSearch 服务代理地址。
GROK_API_URL=
GROK_API_KEY=
GROK_MODEL=
TAVILY_API_URL=
TAVILY_API_KEY=
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=
GROK_RETRY_MAX_ATTEMPTS=2
GROK_RETRY_MULTIPLIER=2
GROK_RETRY_MAX_WAIT=30000
